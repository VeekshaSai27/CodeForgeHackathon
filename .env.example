# ── Gemini API Keys (rotating pool) ──────────────────────────────────────────
# Add as many keys as you have. The pool rotates on 429 / rate-limit.
# Single key fallback: just set GEMINI_API_KEY (no suffix).
# GEMINI_API_KEY=your_single_key_here
GEMINI_API_KEY_1=AIzaSyBfWB93NsPVJIvLwgUi70lzsFRKGaSkSic 
GEMINI_API_KEY_2=AIzaSyDrF0MikI3Mie7anK83ebg0MiHNDrva-eY
GEMINI_API_KEY_3=AIzaSyDkjlJ3Vefw2J1V600zehHiyXkaNglHVSQ

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=5000
FLASK_DEBUG=false
# Comma-separated allowed origins, or * for all
CORS_ORIGINS=http://localhost:8080

# ── PostgreSQL (Database Service) ────────────────────────────────────────────
POSTGRES_DB=skill_platform
POSTGRES_USER=skill_user
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# In dev, leave empty — Vite proxy (vite.config.ts) forwards to Flask on :5000
# In production, set to your deployed API URL e.g. https://api.yourdomain.com
VITE_API_URL=
