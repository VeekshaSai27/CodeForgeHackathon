# ── Gemini API Keys (rotating pool) ──────────────────────────────────────────
# Add as many keys as you have. The pool rotates on 429 / rate-limit.
# Single key fallback: just set GEMINI_API_KEY (no suffix).
GEMINI_API_KEY=YOUR_API_KEY
# GEMINI_API_KEY_1=your_first_key
# GEMINI_API_KEY_2=your_second_key
# GEMINI_API_KEY_3=your_third_key

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=5000
FLASK_DEBUG=false
# Comma-separated allowed origins, or * for all
CORS_ORIGINS=http://localhost:8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=skill_platform
POSTGRES_USER=skill_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Local dev (running python api_server.py directly):
POSTGRES_HOST=localhost

# Docker (docker compose up) — override in docker-compose.yml automatically:
# POSTGRES_HOST=postgres

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Dev: leave empty — Vite proxy forwards to Flask on :5000
# Production (docker): leave empty — Nginx proxies on same origin
VITE_API_URL=
